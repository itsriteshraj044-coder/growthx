# Apache SPA fallback — serve index.html for any non-file/non-directory route
# so client-side routes (/about, /services, /contact, /admin-gx-8f3a2c, ...)
# don't 404 on direct load or refresh.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Let real files and directories be served as-is
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Everything else -> index.html (React Router handles the route)
  RewriteRule ^ index.html [L]
</IfModule>

# Optional: long-cache the fingerprinted assets, never cache index.html
<IfModule mod_headers.c>
  <FilesMatch "\.(?:js|css|woff2?|png|jpe?g|gif|svg|webp|avif)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>
